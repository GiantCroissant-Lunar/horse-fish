# Horse-fish environment variables
# Copy to .env and fill in real values: cp infra/.env.example infra/.env

# --- Agent runtimes ---

# Dashscope (Alibaba Cloud) — used by Pi runtime (qwen3.5-plus)
DASHSCOPE_API_KEY=

# --- Memory / Knowledge graph ---

# Inception AI — used by Cognee for Mercury 2 LLM
INCEPTION_API_KEY=

# --- Observability ---

# Langfuse (self-hosted via docker-compose)
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
